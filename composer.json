{
    "name": "smourace/sendbox",
    "description": "PHP Email Sender with Symfony Mailer",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "symfony/mailer": "^6.0|^7.0",
        "google/apiclient": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
